# ============================================
# 本地 S3 模擬測試用環境變數
# ============================================
# 搭配 docker-compose.dev-s3.yml 使用
# 用於在本地測試 S3 上傳/下載/Pre-signed URL
# ============================================

PLATFORM=windows
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=mysecret

DB_HOST=localhost
DB_PORT=3307
DB_USER=studio_user
DB_PASSWORD=studio_password
DB_NAME=studio_db

COMFYUI_HOST=localhost
COMFY_HOST=localhost
COMFYUI_PORT=8188

# S3 模擬（指向本地 MinIO）
STORAGE_BACKEND=s3
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=studio-outputs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=

# 不需要 ProxyFix
PROXY_FIX=false
SESSION_COOKIE_SECURE=false
SKIP_WARMUP=true
